# ===========================================
# SkyRate AI Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ===========================================
# Application Settings
# ===========================================
APP_NAME=SkyRate AI
APP_VERSION=2.0.0
DEBUG=false
PORT=8000
# development, staging, production
ENVIRONMENT=development

# ===========================================
# Security - REQUIRED IN PRODUCTION
# ===========================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-in-production

# ===========================================
# Database
# ===========================================
# SQLite (local development only)
# DATABASE_URL=sqlite:///./skyrate.db

# MySQL (Bluehost production) - RECOMMENDED
DATABASE_URL=mysql+pymysql://user:password@host/database

# PostgreSQL (alternative)
# DATABASE_URL=postgresql://user:password@localhost:5432/skyrate

# ===========================================
# Redis (for caching and rate limiting)
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# JWT Authentication
# ===========================================
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=90

# ===========================================
# Google OAuth (optional)
# ===========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===========================================
# AI API Keys (at least one required)
# ===========================================
# DeepSeek API
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Google Gemini API
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Anthropic Claude API
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest

# ===========================================
# Compliance Module Feature Flags
# ===========================================
# Enable multi-agent pipeline (Extractor -> Bid Reviewer -> Compliance Officer -> Verifier)
# Default false = single-shot Gemini path (Phase 1 fallback)
COMPLIANCE_USE_AGENTS=false
# Upgrade Compliance Officer agent from Gemini Flash to Gemini Pro (higher cost, deeper reasoning)
# Default false = Flash (~$0.001/doc). True = Pro (~$0.05/doc).
COMPLIANCE_USE_PRO=false

# ===========================================
# Stripe Payments - REQUIRED FOR SUBSCRIPTIONS
# ===========================================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Consultant Plan Price IDs
STRIPE_CONSULTANT_MONTHLY_PRICE_ID=price_xxx
STRIPE_CONSULTANT_YEARLY_PRICE_ID=price_xxx

# Vendor Plan Price IDs
STRIPE_VENDOR_MONTHLY_PRICE_ID=price_xxx
STRIPE_VENDOR_YEARLY_PRICE_ID=price_xxx

# ===========================================
# Email / SMTP (optional for notifications)
# ===========================================
GMAIL_USER=
GMAIL_APP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# ===========================================
# USAC / Socrata (for E-Rate data)
# ===========================================
SOCRATA_APP_TOKEN=

# ===========================================
# perf_v2 — USAC cache + nightly refresh job
# ===========================================
# When true, the consultant endpoints (/crns, /schools, /dashboard-stats)
# serve cache-first from user_usac_cache. Background hydration runs on
# signup, login (when cache is stale), manual sync, and nightly cron.
PERF_V2_ENABLED=false
# Shared secret required by POST /v1/admin/jobs/usac-nightly-refresh and
# the backfill endpoint. Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave blank to refuse all admin job calls (returns 503).
NIGHTLY_JOB_TOKEN=

# ===========================================
# Subscription Pricing (in cents)
# ===========================================
# Consultants: $300/month or $3,000/year
CONSULTANT_MONTHLY_PRICE=30000
CONSULTANT_YEARLY_PRICE=300000
# Vendors: $200/month or $2,000/year
VENDOR_MONTHLY_PRICE=20000
VENDOR_YEARLY_PRICE=200000

# ===========================================
# CORS Allowed Origins
# ===========================================
# Comma-separated list or leave default
# ALLOWED_ORIGINS=http://localhost:3000,https://skyrate.ai

# ===========================================
# Compliance Validation Harness
# ===========================================
# Admin credentials for app.erateapp.com (Stage 1 corpus build)
ERATEAPP_ADMIN_EMAIL=
ERATEAPP_ADMIN_PASSWORD=
# Socrata app token for USAC Open Data (optional, improves rate limits)
USAC_APP_TOKEN=
# Stable salt for entity anonymization (use a random string; changing it
# invalidates previously generated anon_ids)
VALIDATION_SALT=
# Compliance API URL for evaluation (default: local backend)
COMPLIANCE_API_URL=http://localhost:8000
