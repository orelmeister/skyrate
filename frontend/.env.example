# ===========================================
# SkyRate AI Frontend - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!

# ===========================================
# API Configuration
# ===========================================
# Backend API URL (port 8001 for local, production URL for deploy)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ===========================================
# Stripe (for payment forms)
# ===========================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ===========================================
# Application Settings
# ===========================================
NEXT_PUBLIC_APP_NAME=SkyRate AI
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# Feature Flags (optional)
# ===========================================
# NEXT_PUBLIC_ENABLE_ANALYTICS=false
# NEXT_PUBLIC_ENABLE_DEMO_MODE=false

# ===========================================
# Push Notifications (VAPID)
# ===========================================
NEXT_PUBLIC_VAPID_KEY=your-vapid-public-key-here

# ===========================================
# Analytics
# ===========================================
# Google Analytics 4 Measurement ID (e.g., G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=
# Microsoft Clarity Project ID
NEXT_PUBLIC_CLARITY_ID=

# ===========================================
# Communication Channels
# ===========================================
# Tawk.to Live Chat — format: {property_id}/{widget_id}
NEXT_PUBLIC_TAWKTO_ID=
# Booking URL (Google Calendar Appointment Schedule)
NEXT_PUBLIC_CALENDLY_URL=https://calendar.app.google/NgrfWyBXME1PGEgP7
# LinkedIn company page URL
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/company/skyrate-llc

# ===========================================
# Lead Capture
# ===========================================
# Form submission endpoint (Formspree, Getform, or custom backend URL)
# e.g. https://formspree.io/f/xxxxxxxx or https://getform.io/f/xxxxxxxx
NEXT_PUBLIC_FORM_ENDPOINT=